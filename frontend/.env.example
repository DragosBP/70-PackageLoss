# Copy this file to .env.local and fill in your Firebase project credentials.
# Values prefixed with EXPO_PUBLIC_ are inlined at build time by Expo and
# exposed to client-side code.  Do NOT commit .env.local to version control.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
